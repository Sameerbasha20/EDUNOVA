DJANGO_SECRET_KEY=change-this-in-production
# DEBUG must be False on any host reachable from the internet. Only set True
# on your own local machine.
DEBUG=True
# DEV_STATIC_OTP must NEVER be True outside your own local machine — when
# True, every OTP login becomes "123456". It is intentionally a separate
# flag from DEBUG so a rushed deploy with DEBUG=True can't also open this.
# NOTE: DEV_STATIC_OTP is no longer used — OTP is now delivered via email.
# Remove this line or leave it False.
DEV_STATIC_OTP=False
ALLOWED_HOSTS=localhost,127.0.0.1

# Supabase Dashboard > Project Settings > Database > Connection string > URI
DATABASE_URL=postgres://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
DB_SSL_REQUIRE=True

# Frontend dev server
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Supabase Storage/API - server only, do not put service role key in frontend
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Encryption key for `python manage.py backup_database`
BACKUP_ENCRYPTION_KEY=

# ---------------------------------------------------------------------------
# SMTP Email Configuration
# OTP login codes are delivered via email. Configure one of the providers below.
# ---------------------------------------------------------------------------

# --- Option 1: Console backend (development — prints email to terminal) ---
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=no-reply@edunovaacademy.edu.in

# --- Option 2: Gmail (production) ---
# 1. Enable 2-Step Verification on your Google account
# 2. Go to Google Account > Security > App Passwords
# 3. Generate an App Password for "Mail"
# 4. Use that 16-character password as EMAIL_HOST_PASSWORD
#
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your@gmail.com
# EMAIL_HOST_PASSWORD=xxxx-xxxx-xxxx-xxxx
# DEFAULT_FROM_EMAIL=EduNova Academy <your@gmail.com>

# --- Option 3: Brevo (formerly Sendinblue) ---
# Sign up at https://app.brevo.com → SMTP & API → SMTP tab
#
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp-relay.brevo.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your@email.com
# EMAIL_HOST_PASSWORD=your-brevo-smtp-key
# DEFAULT_FROM_EMAIL=EduNova Academy <no-reply@yourdomain.com>

# --- Option 4: Mailtrap (safe email testing — never delivers to real inboxes) ---
# Sign up at https://mailtrap.io → Email Testing → SMTP Settings
#
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=sandbox.smtp.mailtrap.io
# EMAIL_PORT=2525
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-mailtrap-user
# EMAIL_HOST_PASSWORD=your-mailtrap-password
# DEFAULT_FROM_EMAIL=no-reply@edunovaacademy.edu.in
